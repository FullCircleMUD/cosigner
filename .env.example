# XRPL Co-Signing Service — Environment Variables
#
# Copy to .env and fill in values. Never commit .env to version control.

# API key for authenticating requests from clients
API_KEY=change-me-to-a-random-secret

# Path to wallet configuration file (default: ./wallets.json)
# WALLETS_CONFIG=./wallets.json

# Wallet signing seeds — one per configured wallet.
# The env var names must match the "seed_env" values in wallets.json.
# Naming convention: {NETWORK}_SIGNER_B_SEED_{WALLET_NAME}
TESTNET_SIGNER_B_SEED_VAULT=sEdXXXXXXXXXXXXXXXXXXXXXXXXXXX
# TESTNET_SIGNER_B_SEED_ISSUER=sEdXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
